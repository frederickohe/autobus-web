<?xml version="1.0" encoding="utf-8"?>
<!-- Allow HTTP for local Postiz/Chatwoot/Autobus during development (WebView + API). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
